#!/usr/bin/env bash
# claude-tmux-signal — Claude Code hook target. Sets the tmux @claude window flag
# that drives the status-bar glyph:
#   working  (UserPromptSubmit) → animated ✻  — Claude is busy (claude-tmux-spinner)
#   waiting  (Notification)     → red ●        — Claude needs your input
#   done     (Stop)            → gold ●        — Claude finished its turn
#   clear    (SessionEnd)       → nothing      — session gone / idle
# waiting/done only flag windows you are NOT looking at (and fire a macOS
# notification); on the window you're already viewing they just clear the flag,
# so the ✻ stops. Wired up in ~/.claude/settings.json.
#
#   usage:  claude-tmux-signal <working|waiting|done|clear>

set -uo pipefail
state=${1:-}

payload=$(cat 2>/dev/null || true)
msg=$(printf '%s' "$payload" | jq -r '.message // empty' 2>/dev/null || true)

# Nothing to do outside tmux (Claude Code's own notifier still handles the rest).
[ -n "${TMUX:-}" ] && [ -n "${TMUX_PANE:-}" ] || exit 0

win=$(tmux display -p -t "$TMUX_PANE" '#{window_id}' 2>/dev/null || true)
wname=$(tmux display -p -t "$TMUX_PANE" '#{window_name}' 2>/dev/null || true)
active=$(tmux display -p -t "$TMUX_PANE" '#{window_active}' 2>/dev/null || echo 1)
[ -n "$win" ] || exit 0

case "$state" in
  clear)
    tmux set -w -t "$win" -u @claude 2>/dev/null || true
    ;;
  working)
    tmux set -w -t "$win" @claude working 2>/dev/null || true
    # Kick off the animator (no-op if one is already running).
    tmux run-shell -b "$HOME/.local/bin/claude-tmux-spinner" 2>/dev/null || true
    ;;
  waiting|done)
    if [ "$active" != 1 ]; then
      # You're not looking — flag the window and nudge you.
      tmux set -w -t "$win" @claude "$state" 2>/dev/null || true
      title="Claude · ${wname:-session}"
      if [ -n "$msg" ]; then body=$msg
      elif [ "$state" = waiting ]; then body="needs your input"
      else body="finished"; fi
      osascript -e "display notification \"${body//\"/\\\"}\" with title \"${title//\"/\\\"}\"" >/dev/null 2>&1 || true
    else
      # You're already on this window — no dot needed, and stop the ✻.
      tmux set -w -t "$win" -u @claude 2>/dev/null || true
    fi
    ;;
esac
exit 0
