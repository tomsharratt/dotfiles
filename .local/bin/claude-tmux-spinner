#!/usr/bin/env bash
# claude-tmux-spinner — animates the ✻ "working" glyph in the tmux status bar.
# While any window's @claude option is "working" (set by claude-tmux-signal), this
# cycles a shared frame in the global @claude_spin option and forces a fast status
# redraw so the star pulses like Claude's own spinner. Runs as a single background
# instance and exits on its own once nothing is working. Launched by
# claude-tmux-signal; the status format falls back to a static ✻ if it isn't running.
set -uo pipefail
[ -n "${TMUX:-}" ] || exit 0

# Single instance — atomic mkdir lock (macOS has no flock). Reclaim a stale lock
# whose owner has died (e.g. after a SIGKILL that skipped the cleanup trap).
lock="${TMPDIR:-/tmp}/claude-tmux-spinner.lock"
mkdir "$lock" 2>/dev/null || {
  oldpid=$(cat "$lock/pid" 2>/dev/null || true)
  if [ -n "$oldpid" ] && kill -0 "$oldpid" 2>/dev/null; then exit 0; fi
  rm -rf "$lock"; mkdir "$lock" 2>/dev/null || exit 0
}
echo $$ >"$lock/pid"
trap 'tmux set -g -u @claude_spin 2>/dev/null; rm -rf "$lock" 2>/dev/null' INT TERM HUP EXIT

# Pulse mirrors Claude's ✻: small star grows, then shrinks.
frames=(✢ ✳ ✶ ✻ ✽ ✻ ✶ ✳)
i=0
check=0
while :; do
  # Re-scan for working windows about once a second, not every frame (one fork).
  if [ "$check" -le 0 ]; then
    tmux list-windows -a -F '#{@claude}' 2>/dev/null | grep -q '^working$' || break
    check=7
  fi
  # Advance the frame and repaint the status line in a single tmux round-trip.
  tmux set -g @claude_spin "${frames[$i]}" \; refresh-client -S 2>/dev/null || break
  i=$(( (i + 1) % ${#frames[@]} ))
  check=$(( check - 1 ))
  sleep 0.14
done
