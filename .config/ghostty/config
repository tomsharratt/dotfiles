# Font
font-family = Hack Nerd Font
font-size = 14

# Window
window-padding-x = 4
window-padding-y = 4
background-opacity = 0.9
background-blur-radius = 20

# Ghostty hides the tab bar with a single tab by default on macOS — no config needed

# Keybindings
# NOTE: Ghostty doesn't support running a specific command/cwd in a new split via keybinding.
# The wezterm CMD+SHIFT+P (ecs_console.sh split) can't be fully replicated here.
# This opens a plain right split (33% width isn't configurable per-keybind either).
keybind = super+shift+p=new_split:right

# Colors (matches neovim rose-pine)
theme = "Rose Pine"
cursor-color = ff69b4
